[
  {erlkoenig, [
    %% ── C Runtime ─────────────────────────────────────────────────
    %% Path to erlkoenig_rt binary. 'auto' scans /opt/erlkoenig/rt/
    {rt_path, auto},
    {socket_dir, "/run/erlkoenig/containers/"},
    {spawn_timeout,  30000},
    {go_timeout,     10000},
    {stop_timeout,    5000},

    %% ── Persistent Volumes ────────────────────────────────────────
    %% Root directory for bind-mount volume data. Each volume gets
    %% its own UUID-named subdir. See SPEC-EK-024.
    {volumes_root, <<"/var/lib/erlkoenig/volumes">>},
    %% Disk-usage emitter — polls registered volumes and publishes
    %% `stats.volume.<container>.<persist>` events via AMQP.
    {volume_stats_enabled,     true},
    {volume_stats_interval_ms, 60000},

    %% ── Crashloop Quarantine ──────────────────────────────────────
    %% Binaries that crash `threshold` times in `window_ms` are
    %% placed in a memory-resident quarantine list. Subsequent spawn
    %% attempts for the same binary hash are refused. Lifted on
    %% restart of the erlkoenig service or via the public API.
    {quarantine_enabled,   true},
    {quarantine_threshold, 5},
    {quarantine_window_ms, 60000},

    %% ── Admission Gate ────────────────────────────────────────────
    %% Bounded-concurrency gate around the spawn path. Limits how
    %% many containers can be mid-spawn (socket connect + CMD_SPAWN)
    %% at the same time. Protects the host from burst loads.
    %% `admission_max_host` = 0 disables the gate entirely.
    %% `admission_max_per_zone` = 0 disables per-zone counting.
    {admission_max_host,           10},
    {admission_max_per_zone,        0},
    {admission_queue_limit,       100},
    {admission_acquire_timeout_ms, 30000},

    %% ── Binary signature verification ─────────────────────────────
    %% mode: on (reject unsigned) | warn (log only) | off (disabled)
    {signature, #{
        mode => off,
        trust_roots => [],
        min_chain_depth => 2
    }},

    %% ── AMQP Event Bridge (optional) ─────────────────────────────
    %% Publishes container lifecycle, stats, firewall, conntrack,
    %% guard, and system events to RabbitMQ.
    %% Set enabled => false or remove this block to disable.
    {amqp, #{
        enabled => false,
        host => "127.0.0.1",
        port => 5672,
        user => <<"guest">>,
        password => <<"guest">>
    }},

    %% ── Resource protection (cgroups v2) ──────────────────────────
    {resource_protection, #{
        %% beam/ cgroup — protects the BEAM from container pressure
        beam_memory_min  => 268_435_456,    %% 256 MB — kernel memory.min guarantee
        beam_memory_max  => 536_870_912,    %% 512 MB — leak protection ceiling
        beam_cpu_weight  => 200,            %% 2x default scheduling priority
        beam_pids_max    => 8192,           %% BEAM processes + schedulers

        %% containers/ cgroup — aggregate ceiling for all containers
        %% 'auto' = MemTotal - host_reserve - beam_memory_max
        containers_memory_max => auto,
        containers_pids_max   => 24576,

        %% Host reserve (not enforced, used in auto-calculation)
        host_reserve => 1_073_741_824,      %% 1 GB for OS + systemd + SSH

        %% Admission control
        containers_max => 200,              %% Hard cap on concurrent containers
        require_memory_limit => false,      %% Allow containers without memory limit
        require_pids_limit   => false       %% Allow containers without pids limit
    }}
  ]}
].
