[
  {erlkoenig, [
    {bridge_name, <<"erlkoenig_br0">>},
    {subnet,      {10, 0, 0, 0}},
    {gateway,     {10, 0, 0, 1}},
    {netmask,     24},
    {rt_path, auto},
    {spawn_timeout,  30000},
    {go_timeout,     10000},
    {stop_timeout,    5000},

    %% Binary signature verification
    %% mode: on (enforce) | warn (log only) | off (disabled)
    {signature, #{
        mode => off,
        trust_roots => [],
        min_chain_depth => 2
    }},

    %% Unix Domain Socket directory for C runtime communication
    {socket_dir, "/run/erlkoenig/containers/"},

    %% Resource protection — beam/ and containers/ cgroup limits
    {resource_protection, #{
        %% beam/ cgroup limits
        beam_memory_min  => 268_435_456,    %% 256 MB — hard kernel guarantee
        beam_memory_max  => 536_870_912,    %% 512 MB — leak protection
        beam_cpu_weight  => 200,            %% 2x default priority
        beam_pids_max    => 8192,           %% BEAM processes + schedulers

        %% containers/ ceiling
        %% 'auto' = detect total memory, subtract host_reserve + beam_memory_max
        containers_memory_max => auto,
        containers_pids_max   => 24576,

        %% Host reserve (not enforced by erlkoenig, but used in auto-calculation)
        %% When containers_memory_max = auto:
        %%   containers_memory_max = MemTotal - host_reserve - beam_memory_max
        host_reserve => 1_073_741_824,      %% 1 GB for systemd/journald/SSH/kernel

        %% Admission
        containers_max => 200,              %% Hard cap on concurrent containers
        require_memory_limit => true,       %% Reject containers without memory limit
        require_pids_limit   => true        %% Reject containers without pids limit
    }}
  ]}
].
