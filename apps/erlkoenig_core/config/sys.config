[
  {erlkoenig_core, [
    {bridge_name, <<"erlkoenig_br0">>},
    {subnet,      {10, 0, 0, 0}},
    {gateway,     {10, 0, 0, 1}},
    {netmask,     24},
    {rt_path, auto},
    {spawn_timeout,  30000},
    {go_timeout,     10000},
    {stop_timeout,    5000},

    %% Binary signature verification
    %% mode: on (enforce) | warn (log only) | off (disabled)
    {signature, #{
        mode => off,
        trust_roots => [],
        min_chain_depth => 2
    }},

    %% Communication mode with C runtime
    %% port   - Legacy: stdin/stdout pipe via Erlang Port (default)
    %% socket - New: Unix Domain Socket for crash recovery support
    {comm_mode, port},
    {socket_dir, "/run/erlkoenig/containers/"}
  ]}
].
