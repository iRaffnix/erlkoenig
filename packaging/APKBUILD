# Maintainer: Erlkoenig Contributors
pkgname=erlkoenig-rt
pkgver=0.1.0
pkgrel=0
pkgdesc="Erlkoenig container runtime (C component)"
url="https://github.com/erlkoenig/erlkoenig"
arch="x86_64"
license="Apache-2.0"
makedepends="cmake gcc musl-dev linux-headers"
install="$pkgname.post-install"

# Source: adjust URL for releases
# source="$pkgname-$pkgver.tar.gz::https://github.com/erlkoenig/erlkoenig/archive/v$pkgver.tar.gz"
# For local builds:
source=""
builddir="$srcdir/../../../"

build() {
	cmake -B build-apk \
		-DCMAKE_BUILD_TYPE=Release
	cmake --build build-apk
}

package() {
	install -Dm755 build-apk/erlkoenig_rt \
		"$pkgdir"/usr/lib/erlkoenig/erlkoenig_rt
}
