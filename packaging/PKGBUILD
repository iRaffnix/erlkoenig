# Maintainer: Erlkoenig Contributors
pkgname=erlkoenig-rt
pkgver=0.1.0
pkgrel=1
pkgdesc="Erlkoenig container runtime (C component)"
arch=('x86_64')
url="https://github.com/erlkoenig/erlkoenig"
license=('Apache-2.0')
makedepends=('cmake' 'gcc' 'musl' 'linux-headers')
# source=("$pkgname-$pkgver.tar.gz::https://github.com/erlkoenig/erlkoenig/archive/v$pkgver.tar.gz")
# sha256sums=('SKIP')

build() {
    cd "$srcdir/../../../"
    CC=musl-gcc cmake -B build-pkg \
        -DCMAKE_BUILD_TYPE=Release
    cmake --build build-pkg
}

package() {
    cd "$srcdir/../../../"
    install -Dm755 build-pkg/erlkoenig_rt \
        "$pkgdir/usr/lib/erlkoenig/erlkoenig_rt"
    install -Dm644 LICENSE \
        "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}

post_install() {
    setcap cap_sys_admin,cap_net_admin,cap_sys_chroot,cap_sys_ptrace,cap_setpcap,cap_setuid,cap_setgid,cap_dac_override,cap_bpf,cap_sys_resource+ep \
        /usr/lib/erlkoenig/erlkoenig_rt || true
}

post_upgrade() {
    post_install
}
