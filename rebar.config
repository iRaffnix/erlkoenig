{erl_opts, [debug_info, warnings_as_errors]}.
{minimum_otp_vsn, "28"}.
{deps, [
    {erlkoenig_nft, {git, "https://github.com/iRaffnix/erlkoenig_nft.git", {branch, "main"}}}
]}.

{project_app_dirs, ["apps/*"]}.

{shell, [
    {config, "apps/erlkoenig_core/config/sys.config"},
    {apps, [erlkoenig_core]}
]}.

{dialyzer, [
    {warnings, [
        error_handling,
        unmatched_returns
    ]},
    {plt_extra_apps, [crypto]}
]}.

{edoc_opts, [{preprocess, true}]}.

{project_plugins, [erlfmt, rebar3_hex, rebar3_ex_doc]}.

{erlfmt, [write]}.

{xref_checks, [
    undefined_function_calls,
    undefined_functions,
    locals_not_used,
    deprecated_function_calls
]}.

{hex, [{doc, ex_doc}]}.

{ex_doc, [
    {source_url, <<"https://github.com/iRaffnix/erlkoenig">>},
    {extras, [<<"README.md">>]},
    {main, <<"readme">>},
    {api_reference, true}
]}.

{relx, [
    {release, {erlkoenig, "0.3.0"}, [
        erlkoenig_core,
        erlkoenig_nft,
        crypto,
        inets,
        ssl,
        public_key,
        %% compiler is needed by the erlkoenig-dsl escript (Elixir requires it)
        compiler
    ]},
    {sys_config, "apps/erlkoenig_core/config/sys.config"},
    {vm_args, "apps/erlkoenig_core/config/vm.args"},
    {dev_mode, false},
    {include_erts, true},
    {include_src, false},
    {extended_start_script, true},
    {overlay, [
        {copy, "dist/erlkoenig_run", "bin/erlkoenig_run"},
        {copy, "dist/erlkoenig.service", "dist/erlkoenig.service"},
        {copy, "README.md", "doc/README.md"},
        {copy, "docs/ARCHITECTURE.md", "doc/ARCHITECTURE.md"},
        {copy, "docs/STATIC_BINARIES.md", "doc/STATIC_BINARIES.md"},
        {copy, "docs/BUILD.md", "doc/BUILD.md"},
        {copy, "docs/INSTALL.md", "doc/INSTALL.md"},
        %% DSL examples
        {copy, "dsl/examples/simple_echo.exs", "examples/simple_echo.exs"},
        {copy, "dsl/examples/hardened_worker.exs", "examples/hardened_worker.exs"},
        {copy, "dsl/examples/live_test.exs", "examples/live_test.exs"},
        {copy, "dsl/examples/web_cluster.exs", "examples/web_cluster.exs"},
        {copy, "dsl/examples/multi_zone.exs", "examples/multi_zone.exs"},
        {copy, "dsl/examples/three_tier.exs", "examples/three_tier.exs"},
        {copy, "dsl/examples/microservice_cluster.exs", "examples/microservice_cluster.exs"},
        {copy, "dsl/examples/public_bastion.exs", "examples/public_bastion.exs"},
        {copy, "dsl/examples/caddy_proxy.exs", "examples/caddy_proxy.exs"},
        {copy, "dsl/examples/three_tier_live.exs", "examples/three_tier_live.exs"},
        {copy, "dsl/examples/paranoid_payment.exs", "examples/paranoid_payment.exs"},
        {copy, "dsl/examples/signed_echo.exs", "examples/signed_echo.exs"},
        {copy, "dsl/examples/persistent_archive.exs", "examples/persistent_archive.exs"}
    ]}
]}.

{profiles, [
    {test, [
        {erl_opts, [nowarn_export_all]},
        {deps, [
            {assert, {git, "https://github.com/WhatsApp/assert.git", {branch, "main"}}},
            {proper, "1.4.0"}
        ]}
    ]},
    {prod, [
        {relx, [
            {debug_info, strip}
        ]}
    ]}
]}.
