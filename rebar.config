{erl_opts, [debug_info, warnings_as_errors]}.
{minimum_otp_vsn, "28"}.
{deps, [
    {amqp_client, "~> 4.2"}
]}.

{project_app_dirs, ["apps/*"]}.

{shell, [
    {config, "apps/erlkoenig/config/sys.config"},
    {apps, [erlkoenig]}
]}.

{dialyzer, [
    {warnings, [
        error_handling,
        unmatched_returns
    ]},
    {plt_extra_apps, [crypto]}
]}.

{edoc_opts, [{preprocess, true}]}.

{project_plugins, [erlfmt, rebar3_hex, rebar3_ex_doc]}.

{erlfmt, [write]}.

{xref_checks, [
    undefined_function_calls,
    undefined_functions,
    locals_not_used,
    deprecated_function_calls
]}.

%% External modules from sibling projects (erlkoenig_fuse, erlkoenig_elf, erlkoenig_ingest).
%% These are runtime-optional and not rebar3 dependencies.
{xref_ignores, [
    {erlkoenig_fuse_mount_sup, start_mount, 3},
    {erlkoenig_fuse_mount_sup, stop_mount, 1},
    {erlkoenig_fuse_manifest, save, 2},
    {erlkoenig_elf, parse, 1},
    {erlkoenig_elf, seccomp_profile, 1},
    {erlkoenig_ingest, build_rootfs, 2},
    {erlkoenig_ingest, ingest_binary, 3},
    {erlkoenig_ingest, ingest_inline, 3},
    {erlkoenig_ingest, module_info, 1},
    {erlkoenig_sig, verify_binary, 3}
]}.

{hex, [{doc, ex_doc}]}.

{ex_doc, [
    {source_url, <<"https://github.com/iRaffnix/erlkoenig">>},
    {extras, [<<"README.md">>]},
    {main, <<"readme">>},
    {api_reference, true}
]}.

{relx, [
    {release, {erlkoenig, "0.5.0"}, [
        sasl,
        erlkoenig,
        crypto,
        inets,
        ssl,
        public_key,
        compiler,
        amqp_client
    ]},
    {sys_config, "apps/erlkoenig/config/sys.config"},
    {vm_args_src, "apps/erlkoenig/config/vm.args.src"},
    {dev_mode, false},
    {include_erts, true},
    {include_src, false},
    {extended_start_script, true},
    {overlay, [
        {copy, "bin/erlkoenig_wrapper.sh", "bin/erlkoenig"},
        {copy, "dist/erlkoenig_run", "bin/erlkoenig_run"},
        {copy, "dist/erlkoenig.service", "dist/erlkoenig.service"},
        {copy, "README.md", "doc/README.md"},
        {copy, "docs/ARCHITECTURE.md", "doc/ARCHITECTURE.md"},
        {copy, "docs/STATIC_BINARIES.md", "doc/STATIC_BINARIES.md"},
        {copy, "docs/BUILD.md", "doc/BUILD.md"},
        {copy, "docs/INSTALL.md", "doc/INSTALL.md"},
        %% DSL examples
        {copy, "examples/simple_echo.exs", "examples/simple_echo.exs"},
        {copy, "examples/three_tier_nft.exs", "examples/three_tier_nft.exs"},
        {copy, "examples/pod_supervision.exs", "examples/pod_supervision.exs"},
        {copy, "examples/logged_echo.exs", "examples/logged_echo.exs"},
        {copy, "examples/signed_deployment.exs", "examples/signed_deployment.exs"},
        %% Tools
        {copy, "tools/event_consumer.py", "tools/event_consumer.py"},
        {copy, "tools/stream_consumer.py", "tools/stream_consumer.py"}
    ]}
]}.

{profiles, [
    {test, [
        {erl_opts, [nowarn_export_all]},
        {deps, [
            {assert, {git, "https://github.com/WhatsApp/assert.git", {branch, "main"}}},
            {proper, "1.4.0"}
        ]}
    ]},
    {prod, [
        {relx, [
            {debug_info, strip}
        ]}
    ]}
]}.
